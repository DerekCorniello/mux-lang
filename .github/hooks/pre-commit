#!/bin/sh

STAGED_FILES=$(git diff --cached --name-only)

HAS_RUST=false
HAS_WEBSITE=false

for file in $STAGED_FILES; do
  case "$file" in
    mux-compiler/*|mux-runtime/*|Cargo.toml|Cargo.lock|clippy.toml|scripts/run-checks.sh|scripts/dev-cargo.sh|editor-support/*|mux-syntax-highlighting/*)
      HAS_RUST=true
      ;;
    mux-website/*)
      HAS_WEBSITE=true
      ;;
  esac
done

# If neither matches (e.g. CI config, docs), skip all checks
if [ "$HAS_RUST" = false ] && [ "$HAS_WEBSITE" = false ]; then
  echo "No Rust or website files changed, skipping checks."
  exit 0
fi

FAILED=0

if [ "$HAS_RUST" = true ]; then
  echo "Checking Rust formatting..."
  if ! cargo fmt -- --check; then
    echo ""
    echo "Formatting check failed. Run 'cargo fmt' to fix."
    FAILED=1
  fi
  echo "Formatting OK"

  echo ""
  echo "Running Clippy (warnings denied)..."
  if ! cargo clippy --all-targets --all-features -- -D warnings; then
    echo ""
    echo "Clippy check failed. Fix warnings before committing."
    FAILED=1
  fi
  echo "Clippy OK"

  echo ""
  echo "Running tests..."
  if ! cargo test; then
    echo ""
    echo "Tests failed. Fix failing tests before committing."
    FAILED=1
  fi
  echo "Tests OK"
fi

if [ "$HAS_WEBSITE" = true ]; then
  echo ""
  echo "Running website checks..."
  cd mux-website || exit 1

  echo "Linting..."
  if ! npm run lint; then
    echo "Website linting failed."
    FAILED=1
  fi

  echo "Type checking..."
  if ! npm run typecheck; then
    echo "Website type checking failed."
    FAILED=1
  fi

  echo "Building..."
  if ! npm run build; then
    echo "Website build failed."
    FAILED=1
  fi

  cd ..
  echo "Website checks OK"
fi

if [ "$FAILED" -ne 0 ]; then
  exit 1
fi
