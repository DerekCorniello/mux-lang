**/*.env
# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Auto-generated by build.rs for LLVM detection
.cargo/config.toml

# Build artifacts
*.so
*.vsix
*.ll
mux-syntax-highlighting/textmate-mux/source.mux.json
mux-syntax-highlighting/textmate-mux/vscode-language-mux/source.mux.json
mux-syntax-highlighting/tree-sitter-mux/queries/highlights.scm
mux-syntax-highlighting/tree-sitter-mux/generated/syntax.js
mux-syntax-highlighting/tree-sitter-mux/src/grammar.json
mux-syntax-highlighting/tree-sitter-mux/src/node-types.json
mux-syntax-highlighting/tree-sitter-mux/src/parser.c
mux-syntax-highlighting/tree-sitter-mux/mux.so
mux-syntax-highlighting/textmate-mux/vscode-language-mux/language-mux-*.vsix
test_scripts/*
!test_scripts/*.mux
test_scripts/error_cases/*.mux
!test_scripts/error_cases/*.mux
test_scripts/error_cases/*

.scannerwork/*
ci-artifacts/
.docker-cache/
.docker-home/
**/__pycache__/*
**/__pycache__/
**/*.pyc
.codex
