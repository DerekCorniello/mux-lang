import std.assert
import std.sql

func main() returns void {
    print("Starting sql sqlite smoke test")

    match sql.connect("sqlite::memory:") {
        ok(conn) {
            match conn.execute("CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, active INTEGER, payload BLOB, note TEXT)") {
                ok(_) { print("created users table") }
                err(e) { assert.assert(false, "failed to create table: " + e) }
            }

            match conn.execute_params(
                "INSERT INTO users (id, name, active, payload, note) VALUES (?, ?, ?, ?, ?)",
                [sql.int(1), sql.string("Ada"), sql.bool(true), sql.bytes([65, 66]), sql.null()]
            ) {
                ok(count) { assert.assert(count == 1, "expected first insert count == 1") }
                err(e) { assert.assert(false, "failed to insert first row: " + e) }
            }

            match conn.execute_params(
                "INSERT INTO users (id, name, active, payload, note) VALUES (?, ?, ?, ?, ?)",
                [sql.int(2), sql.string("Linus"), sql.bool(false), sql.bytes([67]), sql.string("ok")]
            ) {
                ok(count) { assert.assert(count == 1, "expected second insert count == 1") }
                err(e) { assert.assert(false, "failed to insert second row: " + e) }
            }

            match conn.query("SELECT id, name, active, payload, note FROM users ORDER BY id") {
                ok(rs) {
                    auto columns = rs.columns()
                    assert.assert(columns.size() == 5, "expected 5 columns")
                    assert.assert(columns[0] == "id", "expected first column id")
                    assert.assert(columns[1] == "name", "expected second column name")
                    assert.assert(columns[2] == "active", "expected third column active")
                    assert.assert(columns[3] == "payload", "expected fourth column payload")
                    assert.assert(columns[4] == "note", "expected fifth column note")

                    auto rows = rs.rows()
                    assert.assert(rows.size() == 2, "expected 2 rows")
                    auto first = rows[0]
                    auto second = rows[1]

                    match first["id"].as_int() {
                        ok(id1) { assert.assert(id1 == 1, "first id mismatch") }
                        err(e) { assert.assert(false, "first id conversion failed: " + e) }
                    }
                    match first["name"].as_string() {
                        ok(name1) {
                            assert.assert(name1 == "Ada", "first name mismatch")
                            print("first row name: " + name1)
                        }
                        err(e) { assert.assert(false, "first name conversion failed: " + e) }
                    }
                    match first["active"].as_bool() {
                        ok(active1) {
                            assert.assert(active1, "first active mismatch")
                            print("first row active: " + active1.to_string())
                        }
                        err(e) { assert.assert(false, "first active conversion failed: " + e) }
                    }
                    match first["payload"].as_bytes() {
                        ok(bytes1) {
                            assert.assert(bytes1.size() == 2, "first payload length mismatch")
                            assert.assert(bytes1[0] == 65, "first payload byte 0 mismatch")
                            assert.assert(bytes1[1] == 66, "first payload byte 1 mismatch")
                        }
                        err(e) { assert.assert(false, "first payload conversion failed: " + e) }
                    }
                    assert.assert(first["note"].is_null(), "first note should be null")

                    match second["id"].as_int() {
                        ok(id2) { assert.assert(id2 == 2, "second id mismatch") }
                        err(e) { assert.assert(false, "second id conversion failed: " + e) }
                    }
                    match second["name"].as_string() {
                        ok(name2) {
                            assert.assert(name2 == "Linus", "second name mismatch")
                            print("second row name: " + name2)
                        }
                        err(e) { assert.assert(false, "second name conversion failed: " + e) }
                    }
                    match second["active"].as_bool() {
                        ok(active2) {
                            assert.assert(!active2, "second active mismatch")
                            print("second row active: " + active2.to_string())
                        }
                        err(e) { assert.assert(false, "second active conversion failed: " + e) }
                    }
                    match second["payload"].as_bytes() {
                        ok(bytes2) {
                            assert.assert(bytes2.size() == 1, "second payload length mismatch")
                            assert.assert(bytes2[0] == 67, "second payload byte mismatch")
                        }
                        err(e) { assert.assert(false, "second payload conversion failed: " + e) }
                    }
                    match second["note"].as_string() {
                        ok(note2) { assert.assert(note2 == "ok", "second note mismatch") }
                        err(e) { assert.assert(false, "second note conversion failed: " + e) }
                    }

                    match rs.next() {
                        some(_) { print("first row available from cursor") }
                        none { assert.assert(false, "expected first row from cursor") }
                    }

                    match rs.next() {
                        some(_) { print("second row available from cursor") }
                        none { assert.assert(false, "expected second row from cursor") }
                    }
                }
                err(e) { assert.assert(false, "query failed: " + e) }
            }

            conn.close()
        }
        err(e) { assert.assert(false, "connect failed: " + e) }
    }

    print("sql sqlite smoke test passed")
}
