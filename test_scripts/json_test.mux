import std.json

// Parse a valid JSON string and stringify compact + pretty
string s = "{\"a\": [1, 2, 3], \"b\": null}"
auto r = json.parse(s)
match r {
  ok(val) {
    string compact = json.stringify(val, none)
    string pretty = json.stringify(val, some(2))
    print(compact)
    print(pretty)

    // Build JSON structures by parsing literal JSON strings and stringify them
    string obj_s = "{\"num\": 42, \"arr\": [1,2,3], \"nested\": {\"x\": true}}"
    match json.parse(obj_s) {
      ok(o) { print(json.stringify(o, some(2))) }
      err(e) { print("unexpected parse error: " + e) }
    }

    string list_s = "[1, 2, 3, 4]"
    match json.parse(list_s) {
      ok(l) { print(json.stringify(l, none)) }
      err(e) { print("unexpected parse error: " + e) }
    }

    // from_map: convert a Mux map -> Json
    auto native_map = {"x": 1, "y": 2}
    match json.from_map(native_map) {
      ok(j) { print(json.stringify(j, some(2))) }
      err(e) { print("from_map failed: " + e) }
    }

    // to_map: convert a Json object -> Mux map
    match json.parse("{\"k\": 10}") {
      ok(jv) {
        match json.to_map(jv) {
          ok(m) { print(m.to_string()) }
          err(e) { print("to_map failed: " + e) }
        }
      }
      err(e) { print("unexpected parse error: " + e) }
    }
  }
  err(msg) { print("parse error: " + msg) }
}

// Parse an invalid JSON string and ensure we receive an error
string bad_s = "{ not valid json }"
auto r2 = json.parse(bad_s)
match r2 {
  ok(_) { print("unexpected ok") }
  err(msg) { print("parse failed as expected: " + msg) }
}
