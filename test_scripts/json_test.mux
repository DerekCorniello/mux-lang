import std.data.json

// Parse a valid JSON string and stringify compact + pretty
string json_str = "{\"a\": [1, 2, 3], \"b\": null}"
match json.parse(json_str) {
  ok(val) {
    // Test compact stringify
    match val.stringify(none) {
      ok(s) { print(s) }
      err(e) { print("stringify compact failed: " + e) }
    }
    // Test pretty stringify with 2-space indent
    match val.stringify(some(2)) {
      ok(s) { print(s) }
      err(e) { print("stringify pretty failed: " + e) }
    }
  }
  err(e) { print("parse failed: " + e) }
}

// Build JSON structures by parsing literal JSON strings and stringify them
print("")

// Test 1: Object with array
match json.parse("{\"arr\": [1, 2, 3, 4], \"nested\": {\"x\": true}, \"num\": 42}") {
  ok(o) {
    match o.stringify(some(2)) {
      ok(s) { print(s) }
      err(e) { print("stringify failed: " + e) }
    }
  }
  err(e) { print("parse object failed: " + e) }
}

print("")

// Test 2: Array
match json.parse("[1, 2, 3, 4]") {
  ok(l) {
    match l.stringify(none) {
      ok(s) { print(s) }
      err(e) { print("stringify failed: " + e) }
    }
  }
  err(e) { print("parse array failed: " + e) }
}

print("")

// Test 3: from_map and stringify
match json.from_map({"x": 1.0, "y": 2.0}) {
  ok(j) {
    match j.stringify(some(2)) {
      ok(s) { print(s) }
      err(e) { print("stringify failed: " + e) }
    }
  }
  err(e) { print("from_map failed: " + e) }
}

print("")

// Test 4: to_map
match json.parse("{\"x\": 1, \"y\": 2}") {
  ok(j) {
    match json.to_map(j) {
      ok(m) { print(m.to_string()) }
      err(e) { print("to_map failed: " + e) }
    }
  }
  err(e) { print("parse failed: " + e) }
}

// Test error cases
print("")
match json.parse("{k: 10}") {
  ok(_) { print("parse succeeded unexpectedly") }
  err(e) { print("parse failed as expected: " + e) }
}
