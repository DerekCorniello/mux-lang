import std.test
import std.dsa.*
import std.dsa.collection.Collection

print(test.ping())
print(test.add(2, 3).to_string())

print("=== STACK TESTS ===")
auto s = stack.Stack<int>.new()
print("stack is_empty: " + s.is_empty().to_string())
s.push(4)
s.push(2)
s.push(9)
s.push(15)
print("stack len: " + s.len().to_string())
print("stack is_empty: " + s.is_empty().to_string())
match s.peek() {
    some(v) { print("stack peek: " + v.to_string()) }
    none { print("stack peek: empty") }
}
match s.pop() {
    some(v) { print("stack pop: " + v.to_string()) }
    none { print("stack pop: empty") }
}
print("stack len after pop: " + s.len().to_string())
print("stack to_list: " + s.to_list().to_string())
s.clear()
print("stack len after clear: " + s.len().to_string())
print("stack is_empty after clear: " + s.is_empty().to_string())

print("=== QUEUE TESTS ===")
auto q = queue.Queue<int>.new()
print("queue is_empty: " + q.is_empty().to_string())
q.enqueue(10)
q.enqueue(20)
q.enqueue(30)
q.enqueue(40)
print("queue len: " + q.len().to_string())
print("queue is_empty: " + q.is_empty().to_string())
match q.peek() {
    some(v) { print("queue peek: " + v.to_string()) }
    none { print("queue peek: empty") }
}
match q.dequeue() {
    some(v) { print("queue dequeue: " + v.to_string()) }
    none { print("queue dequeue: empty") }
}
match q.dequeue() {
    some(v) { print("queue dequeue: " + v.to_string()) }
    none { print("queue dequeue: empty") }
}
print("queue len after dequeues: " + q.len().to_string())
print("queue to_list: " + q.to_list().to_string())
q.clear()
print("queue len after clear: " + q.len().to_string())
print("queue is_empty after clear: " + q.is_empty().to_string())

print("=== HEAP TESTS ===")
auto h = heap.Heap<int>.new()
print("heap is_empty: " + h.is_empty().to_string())
h.push(7)
h.push(1)
h.push(5)
h.push(3)
h.push(10)
print("heap len: " + h.len().to_string())
print("heap is_empty: " + h.is_empty().to_string())
match h.peek() {
    some(v) { print("heap peek (min): " + v.to_string()) }
    none { print("heap peek: empty") }
}
match h.pop() {
    some(v) { print("heap pop (min): " + v.to_string()) }
    none { print("heap pop: empty") }
}
match h.pop() {
    some(v) { print("heap pop (min): " + v.to_string()) }
    none { print("heap pop: empty") }
}
print("heap len after pops: " + h.len().to_string())
print("heap to_list: " + h.to_list().to_string())
h.clear()
print("heap len after clear: " + h.len().to_string())
print("heap is_empty after clear: " + h.is_empty().to_string())

print("=== BINARY TREE TESTS ===")
auto tree = bintree.BinaryTree<int>.new()
print("tree is_empty: " + tree.is_empty().to_string())
tree.insert(5)
tree.insert(1)
tree.insert(8)
tree.insert(3)
tree.insert(12)
print("tree len: " + tree.len().to_string())
print("tree is_empty: " + tree.is_empty().to_string())
print("tree contains 8: " + tree.contains(8).to_string())
print("tree contains 99: " + tree.contains(99).to_string())
print("tree to_list: " + tree.to_list().to_string())
tree.clear()
print("tree len after clear: " + tree.len().to_string())
print("tree is_empty after clear: " + tree.is_empty().to_string())

print("=== GRAPH TESTS ===")
auto g = graph.Graph<string>.new()
print("graph is_empty: " + g.is_empty().to_string())
g.add_vertex("X")
g.add_edge("A", "B")
g.add_edge("A", "C")
g.add_edge("B", "D")
g.add_edge("C", "D")
g.add_edge("D", "E")
print("graph len: " + g.len().to_string())
print("graph is_empty: " + g.is_empty().to_string())
print("graph neighbors of A: " + g.neighbors("A").to_string())
print("graph neighbors of B: " + g.neighbors("B").to_string())
print("graph neighbors of Z: " + g.neighbors("Z").to_string())
print("graph bfs from A: " + g.bfs("A").to_string())
print("graph bfs from D: " + g.bfs("D").to_string())
print("graph to_list: " + g.to_list().to_string())
g.clear()
print("graph len after clear: " + g.len().to_string())
print("graph is_empty after clear: " + g.is_empty().to_string())

print("=== ALGORITHM TESTS ===")
auto unsorted = [9, 3, 5, 1, 7, 2, 8, 4]
print("unsorted: " + unsorted.to_string())
auto sorted = algorithm.sort(unsorted)
print("sorted: " + sorted.to_string())

auto s2 = stack.Stack<int>.new()
s2.push(1)
s2.push(3)
s2.push(5)
s2.push(7)
s2.push(9)
print("search stack: " + s2.to_list().to_string())
print("binary search for 5: " + algorithm.binary_search(s2, 5).to_string())
print("binary search for 1: " + algorithm.binary_search(s2, 1).to_string())
print("binary search for 9: " + algorithm.binary_search(s2, 9).to_string())
print("binary search for 99: " + algorithm.binary_search(s2, 99).to_string())

match algorithm.max(s2) {
    some(v) { print("max: " + v.to_string()) }
    none { print("max: none") }
}

match algorithm.min(s2) {
    some(v) { print("min: " + v.to_string()) }
    none { print("min: none") }
}

print("reverse: " + algorithm.reverse(s2).to_string())

auto empty_stack = stack.Stack<int>.new()
match algorithm.max(empty_stack) {
    some(v) { print("empty max: " + v.to_string()) }
    none { print("empty max: none") }
}

match algorithm.min(empty_stack) {
    some(v) { print("empty min: " + v.to_string()) }
    none { print("empty min: none") }
}

print("=== ALL DSA TESTS COMPLETE ===")
