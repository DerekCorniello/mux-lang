import std.json

// Test that stringify rejects NaN with an error
auto nan_map = {"x": 0.0 / 0.0}
match json.from_map(nan_map) {
  ok(nan_json) {
    match json.stringify(nan_json, none) {
      ok(_) { print("unexpected ok for NaN") }
      err(e) { print("NaN error (expected): " + e) }
    }
  }
  err(e) { print("failed to create Json from map with NaN: " + e) }
}

// Test that stringify rejects positive infinity with an error
auto pos_inf_map = {"x": 1.0 / 0.0}
match json.from_map(pos_inf_map) {
  ok(pos_inf_json) {
    match json.stringify(pos_inf_json, none) {
      ok(_) { print("unexpected ok for +Inf") }
      err(e) { print("+Inf error (expected): " + e) }
    }
  }
  err(e) { print("failed to create Json from map with +Inf: " + e) }
}

// Test that stringify rejects negative infinity with an error
auto neg_inf_map = {"x": -1.0 / 0.0}
match json.from_map(neg_inf_map) {
  ok(neg_inf_json) {
    match json.stringify(neg_inf_json, none) {
      ok(_) { print("unexpected ok for -Inf") }
      err(e) { print("-Inf error (expected): " + e) }
    }
  }
  err(e) { print("failed to create Json from map with -Inf: " + e) }
}

// Test that valid finite floats still work
auto finite_map = {"x": 3.14, "y": -42.0, "z": 0.0}
match json.from_map(finite_map) {
  ok(finite_json) {
    match json.stringify(finite_json, some(2)) {
      ok(s) { print("finite floats ok: " + s) }
      err(e) { print("unexpected error for finite: " + e) }
    }
  }
  err(e) { print("failed to create Json from map with finite: " + e) }
}

print("all NaN/Inf tests completed!")
