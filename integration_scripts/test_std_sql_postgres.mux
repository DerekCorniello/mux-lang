import std.assert
import std.env
import std.sql

func require_env(string key) returns string {
    match env.get(key) {
        some(value) { return value }
        none {
            assert.assert(false, "missing environment variable: " + key)
            return ""
        }
    }
}

func main() returns void {
    auto db_url = require_env("MUX_TEST_POSTGRES_URL")
    print("Starting postgres integration test")

    match sql.connect(db_url) {
        ok(conn) {
            match conn.execute("CREATE TEMP TABLE mux_users (id BIGINT PRIMARY KEY, name TEXT NOT NULL, active BOOLEAN NOT NULL)") {
                ok(_) { print("created temp table") }
                err(e) { assert.assert(false, "failed to create temp table: " + e) }
            }

            match conn.execute_params(
                "INSERT INTO mux_users (id, name, active) VALUES ($1, $2, $3)",
                [sql.int(1), sql.string("Ada"), sql.bool(true)]
            ) {
                ok(count) { assert.assert(count == 1, "expected one inserted row") }
                err(e) { assert.assert(false, "failed to insert first row: " + e) }
            }

            match conn.begin_transaction() {
                ok(tx) {
                    match tx.execute_params(
                        "INSERT INTO mux_users (id, name, active) VALUES ($1, $2, $3)",
                        [sql.int(2), sql.string("Grace"), sql.bool(false)]
                    ) {
                        ok(count) { assert.assert(count == 1, "expected transaction insert") }
                        err(e) { assert.assert(false, "transaction insert failed: " + e) }
                    }

                    match tx.commit() {
                        ok(_) { print("transaction committed") }
                        err(e) { assert.assert(false, "transaction commit failed: " + e) }
                    }
                }
                err(e) { assert.assert(false, "begin transaction failed: " + e) }
            }

            match conn.begin_transaction() {
                ok(tx) {
                    match tx.execute_params(
                        "INSERT INTO mux_users (id, name, active) VALUES ($1, $2, $3)",
                        [sql.int(3), sql.string("Rollback"), sql.bool(true)]
                    ) {
                        ok(count) { assert.assert(count == 1, "expected rollback transaction insert") }
                        err(e) { assert.assert(false, "rollback transaction insert failed: " + e) }
                    }

                    match tx.rollback() {
                        ok(_) { print("transaction rolled back") }
                        err(e) { assert.assert(false, "transaction rollback failed: " + e) }
                    }
                }
                err(e) { assert.assert(false, "begin rollback transaction failed: " + e) }
            }

            match conn.query_params(
                "SELECT id, name, active FROM mux_users WHERE id = $1",
                [sql.int(2)]
            ) {
                ok(rs) {
                    match rs.next() {
                        some(row) {
                            match row["id"].as_int() {
                                ok(id) { assert.assert(id == 2, "expected id 2") }
                                err(e) { assert.assert(false, "failed to read id: " + e) }
                            }
                            match row["name"].as_string() {
                                ok(name) {
                                    assert.assert(name == "Grace", "expected Grace row")
                                    print("postgres row name: " + name)
                                }
                                err(e) { assert.assert(false, "failed to read name: " + e) }
                            }
                            match row["active"].as_bool() {
                                ok(active) { assert.assert(!active, "expected inactive row") }
                                err(e) { assert.assert(false, "failed to read active flag: " + e) }
                            }
                        }
                        none { assert.assert(false, "expected one postgres row") }
                    }
                }
                err(e) { assert.assert(false, "postgres query failed: " + e) }
            }

            match conn.query_params(
                "SELECT id FROM mux_users WHERE id = $1",
                [sql.int(3)]
            ) {
                ok(rs) {
                    match rs.next() {
                        none { print("rollback verification passed") }
                        some(_) { assert.assert(false, "rollback row should not exist") }
                    }
                }
                err(e) { assert.assert(false, "rollback verification query failed: " + e) }
            }

            match conn.query("SELECT does_not_exist FROM mux_users") {
                ok(_) { assert.assert(false, "expected invalid postgres query to fail") }
                err(e) { print("postgres error path validated: " + e) }
            }

            conn.close()
        }
        err(e) { assert.assert(false, "postgres connect failed: " + e) }
    }

    print("postgres integration test passed")
}
