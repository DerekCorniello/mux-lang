import std.assert
import std.data.json
import std.env
import std.net

func require_env(string key) returns string {
    match env.get(key) {
        some(value) { return value }
        none {
            assert.assert(false, "missing environment variable: " + key)
            return ""
        }
    }
}

func main() returns void {
    auto base_url = require_env("MUX_TEST_HTTP_URL")
    auto req_json = "{\"method\":\"POST\",\"url\":\"" + base_url + "/mux?case=external\",\"headers\":{\"Accept\":\"application/json\"},\"body\":{\"message\":\"hello\",\"count\":2}}"
    print("Starting external http integration test")

    match json.parse(req_json) {
        ok(req) {
            match net.http.request(req) {
                ok(resp_json) {
                    match json.to_map(resp_json) {
                        ok(resp_map) {
                            match resp_map["status"].stringify(none) {
                                ok(status) {
                                    assert.assert(status == "200" || status == "200.0", "unexpected status: " + status)
                                }
                                err(e) { assert.assert(false, "failed to stringify status: " + e) }
                            }

                            match json.to_map(resp_map["body"]) {
                                ok(body_map) {
                                    match body_map["method"].stringify(none) {
                                        ok(method) { assert.assert(method == "\"POST\"", "unexpected method: " + method) }
                                        err(e) { assert.assert(false, "failed to stringify method: " + e) }
                                    }
                                    match body_map["path"].stringify(none) {
                                        ok(path) { assert.assert(path == "\"/mux\"", "unexpected path: " + path) }
                                        err(e) { assert.assert(false, "failed to stringify path: " + e) }
                                    }
                                    match body_map["query"].stringify(none) {
                                        ok(query) { assert.assert(query == "\"case=external\"", "unexpected query: " + query) }
                                        err(e) { assert.assert(false, "failed to stringify query: " + e) }
                                    }
                                    match json.to_map(body_map["body"]) {
                                        ok(request_body) {
                                            match request_body["message"].stringify(none) {
                                                ok(message) { assert.assert(message == "\"hello\"", "unexpected message: " + message) }
                                                err(e) { assert.assert(false, "failed to stringify message: " + e) }
                                            }
                                        }
                                        err(e) { assert.assert(false, "response body payload was not object json: " + e) }
                                    }
                                }
                                err(e) { assert.assert(false, "response body was not a map: " + e) }
                            }
                        }
                        err(e) { assert.assert(false, "response was not a map: " + e) }
                    }
                }
                err(e) { assert.assert(false, "http request failed: " + e) }
            }
        }
        err(e) { assert.assert(false, "failed to parse request json: " + e) }
    }

    match json.parse("{\"url\":\"" + base_url + "/mux\"}") {
        ok(invalid_req) {
            match net.http.request(invalid_req) {
                ok(_) { assert.assert(false, "expected invalid request to fail") }
                err(e) { print("http invalid-request path validated: " + e) }
            }
        }
        err(e) { assert.assert(false, "failed to parse invalid request json: " + e) }
    }

    print("external http integration test passed")
}
